// file: prisma/schema.prisma — FIXED VERSION

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model Listing {
  id            String        @id @default(cuid())
  title         String
  slug          String        @unique
  description   String
  location      String
  pricePerNight Float
  capacity      Int
  images        String[]
  amenities     String[]
  category      Category      @default(SURF_CAMP)
  active        Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  bookings      Booking[]
  blockedDates  BlockedDate[]

  // FIX #19: Index for active listings by category (homepage filter)
  @@index([active, category])
}

model Booking {
  id                    String        @id @default(cuid())
  listingId             String
  userId                String
  checkIn               DateTime
  checkOut              DateTime
  guests                Int
  totalPrice            Float
  // FIX #5: Snapshot the nightly price at booking time — immutable after creation
  pricePerNightSnapshot Float
  status                BookingStatus @default(PENDING)
  guestName             String
  guestEmail            String
  guestPhone            String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  listing               Listing       @relation(fields: [listingId], references: [id])
  user                  User          @relation(fields: [userId], references: [id])
  payment               Payment?

  // FIX #19: Indexes for common query patterns
  @@index([listingId, status])    // availability check — most critical
  @@index([userId])               // user's bookings page
  @@index([checkIn, checkOut])    // date range queries
  @@index([createdAt])            // admin dashboard sort
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String        @unique
  stripeSessionId       String        @unique
  stripePaymentIntent   String?       @unique
  amount                Float
  currency              String        @default("eur")
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  booking               Booking       @relation(fields: [bookingId], references: [id])

  // FIX #19: Webhook looks up payment by stripeSessionId and stripePaymentIntent
  @@index([stripePaymentIntent])
}

model BlockedDate {
  id          String   @id @default(cuid())
  listingId   String
  date        DateTime
  reason      String?
  listing     Listing  @relation(fields: [listingId], references: [id])

  // FIX #19: Availability check queries blockedDates by listingId + date range
  @@index([listingId, date])
  // FIX: Prevent duplicate blocked dates for same listing+date
  @@unique([listingId, date])
}

enum Role {
  USER
  ADMIN
}

enum Category {
  SURF_CAMP
  ROOM
  VILLA
  HOSTEL
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}
